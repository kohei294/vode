rules_version = '2';

/**
 * Vode: アプリは `users/{uid}/vode/projects` にユーザーデータを保存する。
 * 認証済みの本人のみ、その uid パス以下を読み書き可能にする。
 *
 * デプロイ例: `firebase deploy --only firestore:rules`
 * （`firebase.json` の `firestore.rules` を参照）
 */
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/vode/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
