# このファイルは「キーの名前」のテンプレートです。実際の値はコミットしないでください。
# 手順: このファイルをコピーして `.env.local` を作成し、Firebase Console の値で埋める。
# Vite が読み込むのは `VITE_` で始まる変数だけです。
#
# 書き方: 値はダブルクォート「"」で囲まないでください。行末にカンマも付けないでください。

VITE_FIREBASE_API_KEY=ここに_Web_API_キー
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
# Storage のバケット名はプロジェクトによって .appspot.com または .firebasestorage.app など
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxx
# Optional (Analytics)
# VITE_FIREBASE_MEASUREMENT_ID=
